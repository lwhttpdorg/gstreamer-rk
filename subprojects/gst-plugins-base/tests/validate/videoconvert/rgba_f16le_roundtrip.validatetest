# Check that a RGBA -> RGBA_F16LE -> RGBA roundtrip through videoconvert
# preserves the source color, half floats quantize the values so a small
# tolerance is needed
meta,
    handles-states=true,
    ignore-eos=true,
    args={
        "videotestsrc num-buffers=2 pattern=solid-color foreground-color=0xff4080c0 ! video/x-raw,format=RGBA,width=160,height=120,framerate=30/1 ! videoconvert name=to_f16 ! video/x-raw,format=RGBA_F16LE ! videoconvert name=from_f16 ! video/x-raw,format=RGBA ! fakesink name=sink sync=false",
    },
    configs={
        "$(validateflow), pad=to_f16:sink, ignored-event-types={ eos, }",
        "$(validateflow), pad=from_f16:src, ignored-event-types={ eos, }",
    }

play
check-last-sample, sink-name=sink, expected-color=(guint)0xff4080c0
stop
