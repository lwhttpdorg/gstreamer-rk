# Common metadata to check videotestsrc producing the floating point RGBA
# formats directly. The format is specified by previously setting variables
# with:
# ```
# set-globals, format="<target format>"
# ```
# and then `include, location="videotestsrc-float.meta"` to setup the test
# with this file.
#
# The video content is a solid color so tests can verify the produced frame
# values with `check-last-sample, expected-color=`.
meta,
    handles-states=true,
    ignore-eos=true,
    args={
        "videotestsrc num-buffers=2 pattern=solid-color foreground-color=0xff4080c0 name=src ! video/x-raw,format=$(format),width=160,height=120,framerate=30/1 ! fakesink name=sink sync=false",
    },
    configs={
        "$(validateflow), pad=src:src, ignored-event-types={ eos, }",
    }
