set-globals, media_dir="$(test_dir)/../../../media/defaults/mp4/"
meta,
    seek=true,
    handles-states=true,
    args = {
      "pushfilesrc location=\"$(media_dir)/lcevc_h264_dualtrack.mp4\" ! qtdemux ! video/x-h264,lcevc=true ! fakesink name=sink",
    },
    configs = {
      [validateflow, pad=sink:sink, record-buffers=true],
    }

pause
seek, name=Seek, rate=1.0, start=2.0, stop="$(duration)", flags="flush"
play
wait, message-type=eos
stop
