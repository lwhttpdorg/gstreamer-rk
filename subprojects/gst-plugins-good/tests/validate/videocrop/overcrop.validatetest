meta,
    args = {
        # Overcropping should output a transparent 1 pixel line
        "videotestsrc num-buffers=1 ! video/x-raw,format=ARGB,width=100,height=100 ! videocrop left=100 right=100 ! fakesink name=sink",
    },
    configs = {
        "$(validateflow), pad=sink:sink, buffers-checksum=sha256",
    }

